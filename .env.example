# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=

# ─── API (apps/api) ───────────────────────────────────────────
BETTER_AUTH_SECRET=
PORT=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
# The support email + app password are configured per-deployment via the
# Settings → Email page and stored encrypted in the DB. Host/port live here
# as env so non-Gmail providers (Outlook, Zoho, etc.) can be supported without
# code changes — defaults are Gmail.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Credential encryption key — generate with: openssl rand -hex 32
EMAIL_CREDS_KEY=

# File Storage — MinIO
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# GitHub OAuth App
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Same value as GITHUB_APP_CLIENT_ID — exposed to dashboard frontend for OAuth redirect
# Set Authorization callback URL in GitHub OAuth App to: {DASHBOARD_URL}/settings/github/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# AI — Gemini (for sentiment analysis, topic classification, CSAT inference)
GEMINI_API_KEY=

# App URLs (used by API for CORS + email links)
PORTAL_URL=
DASHBOARD_URL=
NODE_ENV=

# ─── PORTAL / DASHBOARD (apps/portal, apps/dashboard) ─────────
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_PORTAL_URL=
NEXT_PUBLIC_ASSETS_URL=