# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=

# ─── API (apps/api) ───────────────────────────────────────────
BETTER_AUTH_SECRET=
PORT=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
# Credential encryption key — generate with: openssl rand -hex 32
EMAIL_CREDS_KEY=
# Set to 1 to enable the 30s live-poll cron (leave unset in dev until you have OAuth tokens)
EMAIL_SYNC_LIVE_POLL=

# File Storage — MinIO
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# GitHub OAuth App
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Same value as GITHUB_APP_CLIENT_ID — exposed to dashboard frontend for OAuth redirect
# Set Authorization callback URL in GitHub OAuth App to: {DASHBOARD_URL}/settings/github/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Email OAuth — Google (Gmail REST API)
# Register redirect URI in Google Cloud Console: {OAUTH_CALLBACK_BASE}/api/v1/config/email/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email OAuth — Microsoft (Microsoft Graph REST API)
# Register redirect URI in Azure Entra: {OAUTH_CALLBACK_BASE}/api/v1/config/email/oauth/microsoft/callback
# Scopes: Mail.ReadWrite Mail.Send offline_access
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# OAuth routing — OAUTH_CALLBACK_BASE is the external API URL (where Google/Microsoft redirect back)
# BRIDGE_URL is the Bridge app URL (where the API sends the browser after OAuth completes)
OAUTH_CALLBACK_BASE=
BRIDGE_URL=

# AI — Gemini (for sentiment analysis, topic classification, CSAT inference)
GEMINI_API_KEY=

# App URLs (used by API for CORS + email links)
PORTAL_URL=
DASHBOARD_URL=
NODE_ENV=

# ─── PORTAL / DASHBOARD (apps/portal, apps/dashboard) ─────────
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_PORTAL_URL=
NEXT_PUBLIC_ASSETS_URL=