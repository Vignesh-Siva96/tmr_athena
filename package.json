{
  "name": "tmr-support",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "atlas:gen": "tsx scripts/atlas-gen.ts",
    "qa:new": "node scripts/new-delivery-report.mjs",
    "test": "pnpm test:unit && pnpm test:contract && pnpm test:integration",
    "test:unit": "vitest run --config tests/vitest.unit.config.ts",
    "test:integration": "jest --config tests/jest.integration.config.js",
    "test:contract": "vitest run --config tests/vitest.contract.config.ts",
    "test:security": "vitest run --config tests/vitest.security.config.ts",
    "test:e2e": "tsx tests/e2e/infra.ts up && (playwright test --config tests/playwright.config.ts; ret=$?; tsx tests/e2e/infra.ts down; exit $ret)",
    "test:e2e:infra": "tsx tests/e2e/infra.ts up",
    "test:e2e:infra:down": "tsx tests/e2e/infra.ts down",
    "test:e2e:ui": "tsx tests/e2e/infra.ts up && playwright test --config tests/playwright.config.ts --ui",
    "test:watch": "vitest --config tests/vitest.unit.config.ts",
    "test:coverage": "vitest run --coverage --config tests/vitest.unit.config.ts",
    "worldgraph:view": "cd worldgraph && pnpm dev",
    "worldgraph:check": "cd worldgraph && pnpm validate"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.47.0",
    "@swc/core": "^1.15.40",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^1.6.1",
    "axe-core": "^4.10.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "msw": "^2.14.6",
    "prettier": "latest",
    "supertest": "^7.2.2",
    "testcontainers": "^10.28.0",
    "ts-jest": "^29.4.11",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.1",
    "turbo": "latest",
    "typescript": "^5.0.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.11.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
