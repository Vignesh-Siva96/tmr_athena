  "checklist": [
    {
      "key": "admin-access",
      "title": "Sign in to the dashboard",
      "phase": 1,
      "cases": [
        {
          "id": "admin-access.signin",
          "type": "DO",
          "action": "Open the agent Dashboard (Bridge) and sign in as the admin",
          "see": "You land on the dashboard with your name shown",
          "tags": [
            "bridge"
          ]
        },
        {
          "id": "admin-access.wrong-password",
          "type": "DONT",
          "action": "Try to sign in with the wrong password",
          "see": "A clear error; you stay on the sign-in page",
          "tags": [
            "bridge",
            "negative"
          ]
        }
      ]
    },
    {
      "key": "branding",
      "title": "Branding & general settings",
      "phase": 1,
      "cases": [
        {
          "id": "branding.identity",
          "type": "DO",
          "action": "In Settings → Branding/General, change the app name, colours, and the sign-in page layout, then save",
          "see": "The portal and the sign-in page reflect your changes",
          "tags": [
            "bridge",
            "settings"
          ]
        },
        {
          "id": "branding.logo",
          "type": "DO",
          "action": "Upload a logo image",
          "see": "The logo shows on the portal / sign-in page and is not broken",
          "tags": [
            "bridge",
            "settings"
          ]
        }
      ]
    },
    {
      "key": "email-setup",
      "title": "Connect the support inbox",
      "phase": 1,
      "cases": [
        {
          "id": "email-setup.connect",
          "type": "DO",
          "action": "Settings → Email → connect your mailbox via Google or Microsoft",
          "see": "Shows ‘Connected’ with the provider and email address",
