        {
          "id": "email-setup.backfill",
          "type": "DO",
          "action": "Start (or let it auto-run) the archive/backfill of past mail",
          "see": "A progress bar advances and completes",
          "tags": [
            "bridge",
            "email"
          ]
        },
        {
          "id": "email-setup.reconnect",
          "type": "DO",
          "action": "Disconnect, then reconnect the mailbox",
          "see": "State flips to disconnected, then back to connected",
          "tags": [
            "bridge",
            "email"
          ]
        }
      ]
