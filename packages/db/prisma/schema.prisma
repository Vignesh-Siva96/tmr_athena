generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── APP CONFIG (single row — edited via Settings page) ───────────────────────

model AppConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appName          String  @default("Support")
  logoUrl          String?
  portalTagline    String?
  primaryColor     String  @default("#2563EB")
  accentColor      String  @default("#0EA5E9")
  emailDisplayName String  @default("Support")
  supportEmail     String?
  customDomain     String?

  // GitHub webhook config
  githubWebhookSecret        String?
  webhookVerifiedAt          DateTime?
  fixDeployedLabel           String  @default("fix-deployed")
  pendingConfirmationLabel   String  @default("pending-customer-confirmation")

  // Email OAuth (Google / Microsoft)
  oauthProvider           OAuthProvider?
  oauthEmail              String?
  oauthAccessTokenEnc     String?
  oauthRefreshTokenEnc    String?
  oauthTokenExpiresAt     DateTime?
  oauthScopes             String?
  oauthAliases            String[]         @default([])

  // REST sync checkpoints
  gmailHistoryId          String?
  graphDeltaLink          String?
  archivePageToken        String?
  archiveStatus           ArchiveStatus    @default(IDLE)
  archiveTotalSeen        Int?
  archiveTotalEstimate    Int?

  // Portal auth page layout
  portalAuthLayout      AuthLayout @default(MINIMAL)
  portalHeroHeadline    String?
  portalHeroSubheadline String?
  portalFeatures        String[]   @default([])

  notifications  Notification[]

  // AI bot configuration
  botProvider              BotProvider?
  botApiKeyEnc             String?
  botFallbackAgentId       String?

  // Knowledge base
  kbRootUrl            String?
  kbCrawlStatus        KbCrawlStatus @default(IDLE)
  kbCrawlStartedAt     DateTime?
  kbCrawlFinishedAt    DateTime?
  kbCrawlPagesSeen     Int           @default(0)
  kbCrawlPagesIndexed  Int           @default(0)
  kbCrawlError         String?
  kbLastRecrawledAt    DateTime?

  // Two-phase scan → confirm → embed state
  kbPhase              KbPhase  @default(IDLE)
  kbScanPagesSeen      Int      @default(0)
  kbScanChunkCount     Int      @default(0)
  kbScanTokenEstimate  Int      @default(0)
  kbScanCostUsd        Decimal? @db.Decimal(12, 6)
  kbEmbedChunksDone    Int      @default(0)
  kbEmbedChunksTotal   Int      @default(0)
  kbError              String?

  // Shifts
  timezone             String        @default("UTC")

  // Configurable portal dropdowns
  field1Label    String?
  field1Options  Json     @default("[]")
  field2Label    String?
  field2Options  Json     @default("[]")

  // Mirror customer portal replies into support mailbox as a self-addressed copy
  mirrorPortalRepliesToEmail Boolean @default(true)

  // SLA target for agent first response
  slaFirstResponseHours      Int     @default(4)

  // Maintenance mode + feature flags (master overrides individual flags)
  maintenanceMode            Boolean @default(false)
  featConfirmationEmail      Boolean @default(true)
  featBotReply               Boolean @default(true)
  featAiAnalysis             Boolean @default(true)
  featCsatSurvey             Boolean @default(true)
  featGithubIssueCreation    Boolean @default(true)
}

enum AuthLayout {
  MINIMAL
  BRANDED
}

enum BotProvider {
  GEMINI
  OPENAI
  ANTHROPIC
}

enum KbCrawlStatus {
  IDLE
  RUNNING
  DONE
  FAILED
  CANCELLED
}

enum KbPhase {
  IDLE
  SCANNING
  AWAITING_CONFIRM
  EMBEDDING
  DONE
  FAILED
  CANCELLED
}

enum OAuthProvider {
  GOOGLE
  MICROSOFT
}

enum ArchiveStatus {
  IDLE
  RUNNING
  DONE
  FAILED
  CANCELLED
}

enum ExternalProvider {
  GMAIL
  GRAPH
}

// ─── USERS (customers) ────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email     String   @unique
  name      String?
  avatarUrl String?
  password  String?
  isGuest   Boolean  @default(false)
  googleId  String?  @unique

  source      UserSource   @default(PORTAL)
  category    UserCategory @default(CUSTOMER)
  isVerified  Boolean      @default(false)
  emailStatus EmailStatus  @default(ACTIVE)

  lastActiveAt DateTime?

  tickets         Ticket[]          @relation("TicketCustomer")
  messages        Message[]         @relation("MessageAuthorUser")
  magicTokens     MagicToken[]
  customerNotes   CustomerNote[]
  signals         CustomerSignal[]
  botInteractions BotInteraction[]
  aiUsages        AiUsage[]

  @@index([email])
}

enum UserSource {
  PORTAL
  EMAIL
  INVITE
}

enum UserCategory {
  CUSTOMER
  MARKETING
  PROMOTIONAL
}

enum EmailStatus {
  ACTIVE
  BOUNCING
  BLOCKED
}

model MagicToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  type      MagicTokenType
  expiresAt DateTime
  usedAt    DateTime?

  @@index([userId, type])
}

enum MagicTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ─── AGENTS (internal team) ───────────────────────────────────────────────────

model Agent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email     String    @unique
  name      String
  avatarUrl String?
  password  String?
  googleId  String?   @unique
  role      AgentRole @default(PRIMARY_AGENT)

  isActive     Boolean  @default(true)
  lastActiveAt DateTime?

  inviteToken    String?  @unique
  inviteAccepted Boolean  @default(false)

  assignedTickets   Ticket[]          @relation("TicketAssignee")
  dismissedTickets  Ticket[]          @relation("TicketDismissedBy")
  messages          Message[]         @relation("MessageAuthorAgent")
  customerNotes     CustomerNote[]
  notificationReads NotificationRead[]
  shifts            Shift[]
  botInteractions   BotInteraction[]  @relation("BotInteractionEscalatee")

  @@index([email])
}

enum AgentRole {
  ADMIN
  PRIMARY_AGENT
  SECONDARY_AGENT
}

// ─── SHIFTS ───────────────────────────────────────────────────────────────────

model Shift {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  primaryAgentId String
  primaryAgent   Agent    @relation(fields: [primaryAgentId], references: [id], onDelete: Cascade)

  dayOfWeek      Int      // 0 = Sunday … 6 = Saturday, -1 = every day
  startMinute    Int      // minutes from midnight, 0..1439
  endMinute      Int      // exclusive; wraps if end < start (overnight)
  active         Boolean  @default(true)
  lastAssignedAt DateTime?

  @@index([primaryAgentId])
  @@index([dayOfWeek])
}

// ─── TICKETS ──────────────────────────────────────────────────────────────────

model Ticket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ref      String         @unique
  isTicket Boolean        @default(false)
  title     String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  category  TicketCategory
  field1    String?
  field2    String?
  source      TicketSource  @default(PORTAL)
  isBulk      Boolean       @default(false)

  dismissedAt    DateTime?
  dismissedById  String?
  dismissedBy    Agent?    @relation("TicketDismissedBy", fields: [dismissedById], references: [id])

  userId     String
  user       User   @relation("TicketCustomer", fields: [userId], references: [id])

  assigneeId String?
  assignee   Agent?  @relation("TicketAssignee", fields: [assigneeId], references: [id])

  emailThreadId String  @unique @default(cuid())

  // REST email sync (Gmail / Graph)
  externalThreadId   String?          @unique
  externalProvider   ExternalProvider?

  // AI / customer intelligence
  topicId         String?
  topic           Topic?   @relation(fields: [topicId], references: [id])
  reopenedAt      DateTime?
  reopenCount     Int       @default(0)
  firstResolvedAt DateTime?
  convertedAt     DateTime? // set when an email conversation is converted to a real ticket

  githubIssue     GithubIssue?
  messages        Message[]
  attachments     Attachment[]
  tags            Tag[]
  notifications   Notification[]
  rating          TicketRating?
  aiUsages        AiUsage[]
  signals         CustomerSignal[]
  botInteractions BotInteraction[]

  @@index([status])
  @@index([isTicket])
  @@index([dismissedById])
  @@index([userId])
  @@index([assigneeId])
  @@index([emailThreadId])
  @@index([topicId])
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
  DISMISSED
}

enum TicketPriority {
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  BUG_REPORT
  FEATURE_REQUEST
  QUESTION
  BILLING
  OTHER
}

enum TicketSource {
  PORTAL
  EMAIL
}

// ─── MESSAGES ─────────────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  type      MessageType @default(REPLY)
  body      String
  bodyHtml  String?

  authorUserId  String?
  authorUser    User?   @relation("MessageAuthorUser", fields: [authorUserId], references: [id])

  authorAgentId String?
  authorAgent   Agent?  @relation("MessageAuthorAgent", fields: [authorAgentId], references: [id])

  sentVia        MessageSentVia?
  isInternal     Boolean @default(false)
  authorBotName  String? // set when this message was generated by the AI bot

  messageId         String?  @unique
  externalMessageId String?  @unique
  inReplyTo  String?
  bodyRaw    String?  @db.Text

  // AI sentiment analysis
  sentimentScore Float?
  sentimentLabel SentimentLabel?
  analyzedAt     DateTime?

  attachments Attachment[]
  aiUsages    AiUsage[]
  signals     CustomerSignal[]

  @@index([ticketId])
  @@index([ticketId, createdAt])
  @@index([messageId])
}

enum MessageType {
  REPLY
  INTERNAL_NOTE
  SYSTEM_EVENT
}

enum MessageSentVia {
  PORTAL
  EMAIL
  PORTAL_AND_EMAIL
}

// ─── ATTACHMENTS ──────────────────────────────────────────────────────────────

model Attachment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id])

  filename  String
  mimeType  String
  size      Int
  url       String
  isLink    Boolean @default(false)
  linkUrl   String?
}

// ─── TAGS ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name    String  @unique
  color   String  @default("#71717A")
  tickets Ticket[]
}

// ─── GITHUB ───────────────────────────────────────────────────────────────────

model GithubConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessToken    String
  githubUsername String
  githubUserId   String

  defaultRepo String?
}

model GithubIssue {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketId String @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  issueNumber  Int
  repo         String
  issueUrl     String
  title        String
  state        String @default("open")
  reviewers    Int    @default(0)
  daysOpen     Int    @default(0)
  lastSyncedAt DateTime?
}

// ─── CANNED RESPONSES ─────────────────────────────────────────────────────────

model CannedResponse {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  body String
}

// ─── CUSTOMER NOTES ───────────────────────────────────────────────────────────

model CustomerNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id])

  body String
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())

  type      NotificationType

  // Human-readable content
  title     String
  body      String?

  // Related ticket (if applicable)
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  // GitHub issue context
  githubIssueNumber Int?
  githubRepo        String?
  githubIssueTitle  String?

  // Which AppConfig this notification belongs to (always the single row)
  appConfigId String?
  appConfig   AppConfig? @relation(fields: [appConfigId], references: [id], onDelete: SetNull)

  // Per-agent read tracking
  reads NotificationRead[]

  @@index([createdAt])
  @@index([ticketId])
}

model NotificationRead {
  id             String       @id @default(cuid())
  readAt         DateTime     @default(now())

  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([notificationId, agentId])
}

enum NotificationType {
  GITHUB_FIX_DEPLOYED
  CHURN_RISK_DETECTED
}

// ─── SENTIMENT ────────────────────────────────────────────────────────────────

enum SentimentLabel {
  NEGATIVE
  NEUTRAL
  POSITIVE
}

// ─── AI TOPICS ────────────────────────────────────────────────────────────────

model Topic {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  name        String   @unique
  description String?
  ticketCount Int      @default(0)
  tickets     Ticket[]
}

// ─── TICKET RATING (CSAT) ─────────────────────────────────────────────────────

model TicketRating {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  ticketId    String   @unique
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userRating    Int?
  userComment   String?
  aiRating      Int?
  aiReasoning   String?
  aiEffortScore Int?
  aiSummary     String?
  ratingToken   String   @unique @default(cuid())
  requestedAt   DateTime @default(now())
  ratedAt       DateTime?
}

// ─── CUSTOMER SIGNALS ────────────────────────────────────────────────────────

model CustomerSignal {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())

  type      SignalType
  quote     String
  reason    String?

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  ticketId  String
  ticket    Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId    String
  user      User    @relation(fields: [userId], references: [id])

  reviewed  Boolean  @default(false)

  @@index([type, createdAt])
  @@index([userId])
  @@index([ticketId])
}

enum SignalType {
  CHURN_RISK
  ADVOCACY
}

// ─── AI USAGE (cost tracking) ────────────────────────────────────────────────

enum AiOperation {
  SENTIMENT
  TOPIC
  CSAT
  ATHENA_EMBED
  ATHENA_GENERATE
  KB_CONTEXTUAL_SUMMARY
}

enum AiCallStatus {
  OK
  ERROR
}

model AiUsage {
  id               String       @id @default(cuid())
  createdAt        DateTime     @default(now())
  model            String
  operation        AiOperation
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Decimal      @db.Decimal(12, 6)
  durationMs       Int
  status           AiCallStatus
  errorMessage     String?
  ticketId         String?
  ticket           Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  messageId        String?
  message          Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  userId           String?
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([operation, createdAt])
  @@index([userId])
}

// ─── KNOWLEDGE BASE ───────────────────────────────────────────────────────────

enum SourceStatus {
  PENDING
  FETCHED
  SCANNED
  INDEXED
  FAILED
  SKIPPED
}

model KnowledgeSource {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  url          String         @unique
  title        String?
  contentHash  String?
  status       SourceStatus   @default(PENDING)
  errorMessage String?
  fetchedAt    DateTime?
  indexedAt    DateTime?

  chunks       KnowledgeChunk[]

  @@index([status])
}

model KnowledgeChunk {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())

  sourceId      String
  source        KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  ordinal       Int
  text          String          @db.Text
  contextHeader String?         @db.Text
  headingPath   String[]
  anchor        String?
  deepUrl       String
  tokenCount    Int
  embedding     Unsupported("vector(768)")?

  @@index([sourceId])
  @@index([deepUrl])
}

// ─── BOT INTERACTIONS (observability) ────────────────────────────────────────

model BotInteraction {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())

  ticketId             String
  ticket               Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId               String
  user                 User      @relation(fields: [userId], references: [id])

  messageId            String?
  retrievedChunkIds    String[]
  retrievalTopScore    Float?
  llmConfidence        Float?
  didAnswer            Boolean
  escalatedToAgentId   String?
  escalatedToAgent     Agent?    @relation("BotInteractionEscalatee", fields: [escalatedToAgentId], references: [id], onDelete: SetNull)
  reasoning            String?   @db.Text
  citations            String[]
  latencyMs            Int
  costUsd              Decimal   @db.Decimal(10, 6)
  totalTokens          Int
  promptTokens         Int
  completionTokens     Int

  @@index([ticketId])
  @@index([userId])
  @@index([createdAt])
}
